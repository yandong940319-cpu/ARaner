generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum DraftStatus {
  DRAFT
  GENERATING
  COMPLETED
}

enum ScheduleStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  COMPLETED
  PARTIAL_FAIL
  ARCHIVED
}

model Org {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  members   OrgMember[]
  teams     Team[]
  drafts    Draft[]
  ideas     Idea[]
  assets    Asset[]
  apiKeys   ApiKey[]
  schedules Schedule[]
}

model OrgMember {
  id        String   @id @default(cuid())
  role      Role     @default(MEMBER)
  userId    String
  orgId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  org  Org  @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
}

model Team {
  id      String       @id @default(cuid())
  name    String
  orgId   String

  org     Org          @relation(fields: [orgId], references: [id])
  members TeamMember[]

  @@unique([name, orgId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String

  team Team @relation(fields: [teamId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String   // bcrypt hashed
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  orgMemberships  OrgMember[]
  teamMemberships TeamMember[]
  drafts          Draft[]
  ideas           Idea[]
}

model ApiKey {
  id           String   @id @default(cuid())
  orgId        String
  provider     String   // anthropic | openai | gemini | ...
  role         String   // text | image | video
  label        String   @default("")
  encryptedKey String   // AES-256-GCM
  keyHash      String   // SHA-256 prefix for display
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt()

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId, provider, role])
}

model Draft {
  id               String      @id @default(cuid())
  orgId            String
  title            String      @default("")
  platform         String      @default("xhs")
  mode             String      @default("mix")    // text | mix | video
  tone             String      @default("治愈")
  prompt           String      @default("")
  body             String      @default("")
  coverHue         Int?
  coverAssetId     String?
  status           DraftStatus @default(DRAFT)
  generationResult Json?       // { text_body, cover_url, gallery_urls[], video_url }
  linkedIdeaId     String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt()

  org          Org      @relation(fields: [orgId], references: [id])
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  linkedIdea   Idea?    @relation(fields: [linkedIdeaId], references: [id])
  schedules    Schedule[]
}

model Idea {
  id        String   @id @default(cuid())
  orgId     String
  title     String
  platform  String   @default("xhs")
  category  String   @default("")
  angle     String   @default("")
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  org     Org     @relation(fields: [orgId], references: [id])
  authorId String
  author   User    @relation(fields: [authorId], references: [id])
  drafts   Draft[]
}

model Asset {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  type       String   @default("image") // image | video | copy | logo
  url        String
  size       String   @default("")
  tags       String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt()

  org Org @relation(fields: [orgId], references: [id])
}

model Schedule {
  id          String         @id @default(cuid())
  orgId       String
  draftId     String?
  platform    String         // xhs | yt | tt | fb
  scheduledAt DateTime?
  publishedAt DateTime?
  status      ScheduleStatus @default(DRAFT)
  autoPublish Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt()

  org   Org    @relation(fields: [orgId], references: [id])
  draft Draft? @relation(fields: [draftId], references: [id])
}
