{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/keys/layout,_N_T_/(app)/keys/page,_N_T_/keys"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/keys/__PAGE__",
    "/!KGFwcCk/keys",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}