{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/ideas/layout,_N_T_/(app)/ideas/page,_N_T_/ideas"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/ideas/__PAGE__",
    "/!KGFwcCk/ideas",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}