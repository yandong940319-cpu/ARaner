{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/editor/layout,_N_T_/(app)/editor/page,_N_T_/editor"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/editor/__PAGE__",
    "/!KGFwcCk/editor",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}