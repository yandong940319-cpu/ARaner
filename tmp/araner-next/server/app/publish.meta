{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/publish/layout,_N_T_/(app)/publish/page,_N_T_/publish"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/publish/__PAGE__",
    "/!KGFwcCk/publish",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}